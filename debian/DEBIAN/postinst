#!/bin/bash
# Post-install script
set -e

echo "=== EasyConnect VPN Launcher ==="
echo "正在拉取 EasyConnect Docker 镜像..."

# 尝试拉取镜像（不阻塞安装）
docker pull hagb/docker-easyconnect:cli 2>/dev/null &
DOCKER_PID=$!

echo "安装完成！"
echo ""
echo "使用方法："
echo "  1. 在应用菜单中搜索 'EasyConnect VPN' 点击启动"
echo "  2. 或终端运行: ec-connect"
echo ""
echo "首次使用会自动下载 Docker 镜像，请稍候。"
echo ""

# 等待拉取完成（最多60秒）
wait $DOCKER_PID 2>/dev/null || true
echo "镜像拉取完成！"
